# System metadata noise
.DS_Store
._*
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
Desktop.ini

# Python cache noise
__pycache__/
*.pyc

# Xcode local user state
xcuserdata/
*.xcuserstate

# Local SwiftPM build output
.build/

# Claude Code local state (allow the shared settings.json so attribution
# overrides are committed; everything else under .claude/ stays local).
# Note: ignore contents (.claude/*) rather than the directory itself
# (.claude/) so the !.claude/settings.json negation can re-include the file.
.claude/*
!.claude/settings.json

# Local backup archives
*.tar.gz
