#!/usr/bin/env bash
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel 2>/dev/null || true)"
if [[ -z "$ROOT" ]]; then
  echo "Owlory pre-push provenance check failed: not inside a Git repository." >&2
  exit 1
fi

cd "$ROOT"

echo "Running Owlory pre-push provenance checks..."

dirty_state="$(git status --short --untracked-files=all)"
if [[ -n "$dirty_state" ]]; then
  cat >&2 <<'EOF'
Refusing push: the working tree is dirty.

Why this exists:
  Owlory release/TestFlight proof depends on Xcode build metadata matching
  committed Git history. Pushing while local release metadata or proof files are
  uncommitted recreates unreproducible TestFlight builds.

How to fix:
  Commit the intended changes, or stash/remove unrelated local files, then run:
    ./Tools/verify-build-provenance.sh --require-clean
    make build-provenance

Read next:
  docs/workflows/release.md
EOF
  printf '%s\n' "$dirty_state" >&2
  exit 1
fi

if ! ./Tools/verify-build-provenance.sh --require-clean; then
  cat >&2 <<'EOF'
Pre-push provenance check failed.

Why this exists:
  The Xcode MARKETING_VERSION and CURRENT_PROJECT_VERSION used for TestFlight
  must be reproducible from the committed project.pbxproj at HEAD.

How to fix:
  If you intentionally bumped the app version or build number, commit the
  project.pbxproj bump first. If you did not intend the bump, remove it before
  pushing.

Read next:
  docs/workflows/release.md
EOF
  exit 1
fi

if ! make build-provenance; then
  cat >&2 <<'EOF'
Pre-push build-provenance target failed.

How to fix:
  Run make build-provenance locally, read the specific failure, and repair the
  release metadata before pushing.
EOF
  exit 1
fi

changed_paths=""
upstream="$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null || true)"
if [[ -n "$upstream" ]]; then
  changed_paths="$(git diff --name-only "$upstream"...HEAD)"
else
  changed_paths="$(git diff --name-only HEAD~1..HEAD 2>/dev/null || git ls-files)"
fi

if CHANGED_PATHS="$changed_paths" python3 - "$ROOT/automation/reusable-manifest.json" <<'PY'
from __future__ import annotations

import json
import os
import sys
from pathlib import PurePosixPath

manifest_path = sys.argv[1]
changed = [line.strip() for line in os.environ.get("CHANGED_PATHS", "").splitlines() if line.strip()]
if not changed:
    raise SystemExit(1)

with open(manifest_path, encoding="utf-8") as handle:
    manifest = json.load(handle)

sources: list[tuple[str, str]] = []
for entry in manifest.get("entries", []):
    source = PurePosixPath(entry["source"]).as_posix()
    sources.append((entry["kind"], source))

for path in changed:
    normalized = PurePosixPath(path).as_posix()
    for kind, source in sources:
        if normalized == source or (kind == "directory" and normalized.startswith(f"{source}/")):
            raise SystemExit(0)

raise SystemExit(1)
PY
then
  echo "Reusable repo automation changed; updating external repo-automation target..."
  if ! make repo-automation-update; then
    cat >&2 <<'EOF'
Pre-push repo-automation update failed.

Why this exists:
  Owlory is the current source of truth for reusable automation, and pushes that
  change reusable harness files must keep the external repo-automation folder
  current.

How to fix:
  Read the sync error above. If the external repo is dirty, commit/stash/clean it
  intentionally, then rerun:
    make repo-automation-update
    make repo-automation-check

External Git commits and remote pushes remain explicit operator actions.
EOF
    exit 1
  fi
else
  echo "Reusable repo automation unchanged; skipping repo-automation update."
fi

echo "Pre-push provenance checks passed."
